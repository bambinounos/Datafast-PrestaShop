{
  "name": "datafast/datafast",
  "description": "datafast PrestaShop Payments module",
  "homepage": "https://datafast.com.ec",
  "authors": [
    {
      "name": "Sismetic",
      "email": "notificaciones@sismetic.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*",
    "monolog/monolog": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9"
  },
  "autoload": {
    "psr-4": {
      "datafast\\payment\\": "src/classes/"
    },
    "exclude-from-classmap": []
  },
  "config": {
    "preferred-install": "dist",
    "prepend-autoloader": false
  },
  "type": "prestashop-module"
}
